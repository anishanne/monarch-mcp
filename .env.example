# Monarch Money auth (option A: direct token, option B: auto-login credentials)
MONARCH_TOKEN=your_monarch_money_auth_token
# MONARCH_EMAIL=your@email.com
# MONARCH_PASSWORD=your_password
# MONARCH_MFA_SECRET=your_totp_base32_secret

MCP_AUTH_TOKEN=your_shared_secret_for_oauth
BASE_URL=https://your-deployment.vercel.app
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/?appName=YourApp
PORT=8787
